{
    "name": "dancing-janissary/laravel-seo-indexing",
    "description": "Automatically notify Google Indexing API and IndexNow (Bing, Yandex) on Eloquent model CRUD operations.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "seo",
        "indexing",
        "google",
        "indexnow",
        "bing",
        "yandex",
        "sitemap",
        "search-engine",
        "seznam",
        "naver",
        "search console",
        "multi-language",
        "i18n"
    ],
    "authors": [
        {
            "name": "Hazarcan Doğa Bakan",
            "email": "hazarcandogabakan@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0 || ^12.0",
        "illuminate/http": "^11.0 || ^12.0",
        "illuminate/database": "^11.0 || ^12.0",
        "illuminate/queue": "^11.0 || ^12.0",
        "google/apiclient": "^2.15"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0 || ^10.0",
        "phpunit/phpunit": "^10.5 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "DancingJanissary\\SeoIndexing\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DancingJanissary\\SeoIndexing\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Google\\Task\\Composer::cleanup"
        ],
        "test": "vendor/bin/phpunit"
    },
    "extra": {
        "google/apiclient-services": [
            "Indexing"
        ],
        "laravel": {
            "providers": [
                "DancingJanissary\\SeoIndexing\\SeoIndexingServiceProvider"
            ],
            "aliases": {
                "SeoIndexing": "DancingJanissary\\SeoIndexing\\Facades\\SeoIndexing"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}