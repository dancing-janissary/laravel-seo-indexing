{
    "name": "dancing-janissary/laravel-seo-indexing",
    "description": "Automatically notify Google Indexing API and IndexNow (Bing, Yandex) on Eloquent model CRUD operations.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "seo",
        "indexing",
        "google",
        "indexnow",
        "bing",
        "sitemap"
    ],
    "authors": [
        {
            "name": "Your Name",
            "email": "you@example.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "google/apiclient": "^2.19",
        "google/auth": "^1.34",
        "illuminate/database": "^11.0",
        "illuminate/http": "^11.0",
        "illuminate/queue": "^11.0",
        "illuminate/support": "^11.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "pestphp/pest": "^2.0",
        "pestphp/pest-plugin-laravel": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "DancingJanissary\\SeoIndexing\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DancingJanissary\\SeoIndexing\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "DancingJanissary\\SeoIndexing\\SeoIndexingServiceProvider"
            ],
            "aliases": {
                "SeoIndexing": "DancingJanissary\\SeoIndexing\\Facades\\SeoIndexing"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
